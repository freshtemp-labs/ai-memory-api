# AI Memory API Configuration
DATABASE_PATH=data/memory.db
VECTOR_DB_PATH=data/vectors.db

# Embedding provider: openai, local, or none
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Local embedding (when EMBEDDING_PROVIDER=local)
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Rate limiting
FREE_TIER_LIMIT=100
BASIC_TIER_LIMIT=10000

# API key for admin operations
ADMIN_API_KEY=admin-secret-change-me

# Memory compression
COMPRESSION_THRESHOLD=50
COMPRESSION_BATCH_SIZE=10
